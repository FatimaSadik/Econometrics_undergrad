library(readxl)
fertility <- read_excel("fertility.xlsx")
View(fertility)
library(readxl)
fertility <- read_excel("fertility.xlsx")
View(fertility)
model1<-lm(fertility$weeksm1~fertility$morekids)
summary(model1)
model2<-lm(weeksm1~morekids+agem1,data=fertility)
summary(model2)
iv<-ivreg(weeksm1~morekids|samesex, data=fertility)
library(ivreg)
iv<-ivreg(weeksm1~morekids|samesex, data=fertility)
summary(iv)
