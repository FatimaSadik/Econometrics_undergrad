install.packages("wooldridge")
install.packages("car")
install.packages("dplyr")
library("wooldridge")
library(car)
library(dplyr)
data("phillips")
force(phillips)
View(phillips)
View(phillips)
phillips_static<-lm(inf~unem, data=phillips)
summary(phillips_static)
uhat<-phillips_static$residuals
L.uhat<-lag(uhat,n=1)
serial_corr<-lm(uhat~L.uhat)
summary(serial_corr)
serial_corr<-lm(uhat~L.uhat-1)
summary(serial_corr)
corr(uhat,L.uhat)
cor(uhat,L.uhat)
cor(uhat,L.uhat,use="complete.obs")
#Durbin Watson Test
dw_test <- durbinWatsonTest(phillips_static)
dw_statistic <- sum(diff(uhat)^2) / sum(uhat^2)
print(dw_statistic)
print(dw_test)
# Install and load the quantmod package
install.packages("quantmod")
library(quantmod)
# Define the symbol for GDP data from FRED (Federal Reserve Economic Data)
gdp_symbol <- "GDPC1"
# Download GDP data
getSymbols(gdp_symbol, src = "FRED")
# Plot the GDP data
plot(GDPC1, main = "US GDP Data", ylab = "GDP (in billions of dollars)", col = "blue")
View(GDPC1)
lnGDPC1<-log(GDPC1)
plot(lnGDPC1, main = "US GDP Data", ylab = "Log(GDP)", col = "blue")
dlogGDP<-diff(lnGDPC1)
plot(dlogGDP, main = "US GDP Data", ylab = "GDP Growth", col = "blue")
plot(phillips$unem,type = "l", col = "blue", lwd = 2,
main = "Unemployment",
xlab = "Time", ylab = "Unemployment Rate")
plot(phillips$inf,type = "l", col = "blue", lwd = 2,
main = "Inflation",
xlab = "Time", ylab = "Inflation Rate")
